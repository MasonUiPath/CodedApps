PORT=8080
WS_PATH=/ws
JSON_BODY_LIMIT=1mb

UIPATH_BASE_URL=https://cloud.uipath.com
UIPATH_ORG_NAME=your-org
UIPATH_TENANT_NAME=your-tenant
UIPATH_PAT=your-personal-access-token

# Auth mode options:
# - pat (default if UIPATH_PAT/UIPATH_SECRET is provided)
# - external_app (client credentials, no user auth flow)
# UIPATH_AUTH_MODE=external_app
# UIPATH_CLIENT_ID=your-external-app-client-id
# UIPATH_CLIENT_SECRET=your-external-app-client-secret
# UIPATH_SCOPE=DataFabric.Data.Read DataFabric.Data.Write DataFabric.Schema.Read OR.Folders.Read OR.Buckets.Read
# UIPATH_TOKEN_URL=https://cloud.uipath.com/identity_/connect/token

# UiPath SDK telemetry controls (recommended for local/ngrok dev)
DISABLE_UIPATH_SDK_TELEMETRY=true
SUPPRESS_UIPATH_SDK_TELEMETRY_LOGS=true
